{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Azure Support Agent — 一键部署到 Azure VM（支持已有 VNet/子网或自动创建）"
  },
  "parameters": {
    "vmName": {
      "type": "string",
      "defaultValue": "azure-support-agent",
      "metadata": { "description": "VM 名称" }
    },
    "vmSize": {
      "type": "string",
      "defaultValue": "Standard_B2s",
      "metadata": { "description": "VM 大小" }
    },
    "adminUsername": {
      "type": "string",
      "defaultValue": "azureagent",
      "metadata": { "description": "管理员用户名" }
    },
    "authenticationType": {
      "type": "string",
      "defaultValue": "sshPublicKey",
      "allowedValues": ["sshPublicKey", "password"],
      "metadata": { "description": "认证方式：SSH 公钥（推荐）或密码" }
    },
    "adminPasswordOrKey": {
      "type": "securestring",
      "metadata": { "description": "SSH 公钥内容（ssh-rsa AAAA...）或密码（至少12位，含大小写+数字+特殊字符）" }
    },
    "existingVnetResourceGroup": {
      "type": "string",
      "defaultValue": "",
      "metadata": { "description": "已有 VNet 所在资源组（留空 = 自动创建新 VNet）" }
    },
    "existingVnetName": {
      "type": "string",
      "defaultValue": "",
      "metadata": { "description": "已有 VNet 名称（留空 = 自动创建新 VNet）" }
    },
    "existingSubnetName": {
      "type": "string",
      "defaultValue": "",
      "metadata": { "description": "已有子网名称（留空 = 自动创建）" }
    },
    "gitRepoUrl": {
      "type": "string",
      "defaultValue": "https://github.com/tech-connection/azure-support-agent.git",
      "metadata": { "description": "GitHub 仓库 URL" }
    },
    "gitBranch": {
      "type": "string",
      "defaultValue": "main",
      "metadata": { "description": "Git 分支" }
    },
    "appLogLevel": {
      "type": "string",
      "defaultValue": "INFO",
      "allowedValues": ["DEBUG", "INFO", "WARNING", "ERROR"],
      "metadata": { "description": "日志级别" }
    },
    "feishuAppId": {
      "type": "string",
      "metadata": { "description": "飞书 App ID" }
    },
    "feishuAppSecret": {
      "type": "securestring",
      "metadata": { "description": "飞书 App Secret" }
    },
    "azureOpenaiEndpoint": {
      "type": "string",
      "metadata": { "description": "Azure OpenAI Endpoint URL" }
    },
    "azureOpenaiApiKey": {
      "type": "securestring",
      "metadata": { "description": "Azure OpenAI API Key" }
    },
    "azureOpenaiDeployment": {
      "type": "string",
      "defaultValue": "gpt-4.1",
      "metadata": { "description": "Azure OpenAI 部署名称" }
    },
    "azureOpenaiApiVersion": {
      "type": "string",
      "defaultValue": "preview",
      "metadata": { "description": "Azure OpenAI API Version" }
    },
    "azureSubscriptionId": {
      "type": "string",
      "metadata": { "description": "Agent 要管理的 Azure Subscription ID" }
    },
    "azureTenantId": {
      "type": "string",
      "metadata": { "description": "Azure Tenant ID" }
    },
    "azureClientId": {
      "type": "string",
      "metadata": { "description": "Service Principal Client ID" }
    },
    "azureClientSecret": {
      "type": "securestring",
      "metadata": { "description": "Service Principal Client Secret" }
    }
  },
  "variables": {
    "location": "[resourceGroup().location]",
    "useExistingVnet": "[and(not(empty(parameters('existingVnetName'))), not(empty(parameters('existingSubnetName'))))]",
    "newVnetName": "[concat(parameters('vmName'), '-vnet')]",
    "newSubnetName": "default",
    "nsgName": "[concat(parameters('vmName'), '-nsg')]",
    "pipName": "[concat(parameters('vmName'), '-pip')]",
    "nicName": "[concat(parameters('vmName'), '-nic')]",
    "existingSubnetId": "[if(and(not(empty(parameters('existingVnetName'))), not(empty(parameters('existingSubnetName')))), resourceId(if(empty(parameters('existingVnetResourceGroup')), resourceGroup().name, parameters('existingVnetResourceGroup')), 'Microsoft.Network/virtualNetworks/subnets', parameters('existingVnetName'), parameters('existingSubnetName')), 'placeholder')]",
    "newSubnetId": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('newVnetName'), variables('newSubnetName'))]",
    "subnetId": "[if(variables('useExistingVnet'), variables('existingSubnetId'), variables('newSubnetId'))]",
    "linuxConfigSsh": {
      "disablePasswordAuthentication": true,
      "ssh": {
        "publicKeys": [
          {
            "path": "[concat('/home/', parameters('adminUsername'), '/.ssh/authorized_keys')]",
            "keyData": "[parameters('adminPasswordOrKey')]"
          }
        ]
      }
    },
    "linuxConfigPassword": {
      "disablePasswordAuthentication": false
    },
    "linuxConfiguration": "[if(equals(parameters('authenticationType'), 'sshPublicKey'), variables('linuxConfigSsh'), variables('linuxConfigPassword'))]",
    "cloudInitScript": "[base64(concat('#!/bin/bash\nexec > /var/log/agent-deploy.log 2>&1\necho \"=== Azure Support Agent deployment started at $(date) ===\"\n\nAPP_DIR=\"/opt/azure-support-agent\"\nAPP_USER=\"', parameters('adminUsername'), '\"\n\n# ── 1. 安装系统依赖 ──\napt-get update -y\napt-get install -y software-properties-common git\nadd-apt-repository -y ppa:deadsnakes/ppa\napt-get update -y\napt-get install -y python3.13 python3.13-venv\n\nif ! command -v python3.13 &>/dev/null; then\n  echo \"ERROR: python3.13 not installed\" && exit 1\nfi\n\n# ── 2. 克隆代码 ──\nif [ -d \"$APP_DIR\" ]; then\n  cd \"$APP_DIR\" && git fetch --all && git checkout ', parameters('gitBranch'), ' && git pull\nelse\n  git clone -b ', parameters('gitBranch'), ' ', parameters('gitRepoUrl'), ' \"$APP_DIR\"\nfi\n\ncd \"$APP_DIR\"\n\n# ── 3. Python 虚拟环境 ──\npython3.13 -m venv .venv\nsource .venv/bin/activate\npip install --upgrade pip\npip install -r requirements.txt || echo \"WARNING: pip install had errors, check log\"\n\n# ── 4. 写入 .env ──\ncat > .env << ENVEOF\nAZURE_SUBSCRIPTION_ID=', parameters('azureSubscriptionId'), '\nAZURE_AUTH_MODE=spn\nAZURE_TENANT_ID=', parameters('azureTenantId'), '\nAZURE_CLIENT_ID=', parameters('azureClientId'), '\nAZURE_CLIENT_SECRET=', parameters('azureClientSecret'), '\nAZURE_OPENAI_ENDPOINT=', parameters('azureOpenaiEndpoint'), '\nAZURE_OPENAI_API_KEY=', parameters('azureOpenaiApiKey'), '\nAZURE_OPENAI_API_VERSION=', parameters('azureOpenaiApiVersion'), '\nAZURE_OPENAI_DEPLOYMENT=', parameters('azureOpenaiDeployment'), '\nFEISHU_APP_ID=', parameters('feishuAppId'), '\nFEISHU_APP_SECRET=', parameters('feishuAppSecret'), '\nAPP_LOG_LEVEL=', parameters('appLogLevel'), '\nENVEOF\n\nchmod 600 .env\nmkdir -p logs\n\n# ── 5. 配置 systemd 服务 ──\ncat > /etc/systemd/system/azure-support-agent.service << SVCEOF\n[Unit]\nDescription=Azure Support Agent (Feishu Long Connection)\nAfter=network-online.target\nWants=network-online.target\n\n[Service]\nType=simple\nUser=', parameters('adminUsername'), '\nWorkingDirectory=/opt/azure-support-agent\nExecStart=/opt/azure-support-agent/.venv/bin/python -m app.main\nRestart=always\nRestartSec=10\nEnvironment=PYTHONUNBUFFERED=1\n\n[Install]\nWantedBy=multi-user.target\nSVCEOF\n\nchown -R \"$APP_USER\":\"$APP_USER\" \"$APP_DIR\"\nsystemctl daemon-reload\nsystemctl enable azure-support-agent\nsystemctl start azure-support-agent\n\necho \"=== Deployment finished at $(date) ===\"\n'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2023-11-01",
      "name": "[variables('nsgName')]",
      "location": "[variables('location')]",
      "properties": {
        "securityRules": [
          {
            "name": "AllowSSH",
            "properties": {
              "priority": 1000,
              "direction": "Inbound",
              "access": "Allow",
              "protocol": "Tcp",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "22"
            }
          }
        ]
      }
    },
    {
      "condition": "[not(variables('useExistingVnet'))]",
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2023-11-01",
      "name": "[variables('newVnetName')]",
      "location": "[variables('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkSecurityGroups', variables('nsgName'))]"
      ],
      "properties": {
        "addressSpace": { "addressPrefixes": ["10.0.0.0/16"] },
        "subnets": [
          {
            "name": "[variables('newSubnetName')]",
            "properties": {
              "addressPrefix": "10.0.0.0/24",
              "networkSecurityGroup": {
                "id": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('nsgName'))]"
              }
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2023-11-01",
      "name": "[variables('pipName')]",
      "location": "[variables('location')]",
      "sku": { "name": "Standard" },
      "properties": {
        "publicIPAllocationMethod": "Static"
      }
    },
    {
      "type": "Microsoft.Network/networkInterfaces",
      "apiVersion": "2023-11-01",
      "name": "[variables('nicName')]",
      "location": "[variables('location')]",
      "dependsOn": [
        "[if(variables('useExistingVnet'), resourceId('Microsoft.Network/publicIPAddresses', variables('pipName')), resourceId('Microsoft.Network/virtualNetworks', variables('newVnetName')))]",
        "[resourceId('Microsoft.Network/publicIPAddresses', variables('pipName'))]",
        "[resourceId('Microsoft.Network/networkSecurityGroups', variables('nsgName'))]"
      ],
      "properties": {
        "ipConfigurations": [
          {
            "name": "ipconfig1",
            "properties": {
              "subnet": { "id": "[variables('subnetId')]" },
              "publicIPAddress": {
                "id": "[resourceId('Microsoft.Network/publicIPAddresses', variables('pipName'))]"
              },
              "privateIPAllocationMethod": "Dynamic"
            }
          }
        ],
        "networkSecurityGroup": {
          "id": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('nsgName'))]"
        }
      }
    },
    {
      "type": "Microsoft.Compute/virtualMachines",
      "apiVersion": "2024-03-01",
      "name": "[parameters('vmName')]",
      "location": "[variables('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkInterfaces', variables('nicName'))]"
      ],
      "properties": {
        "hardwareProfile": { "vmSize": "[parameters('vmSize')]" },
        "osProfile": {
          "computerName": "[parameters('vmName')]",
          "adminUsername": "[parameters('adminUsername')]",
          "adminPassword": "[if(equals(parameters('authenticationType'), 'password'), parameters('adminPasswordOrKey'), null())]",
          "linuxConfiguration": "[variables('linuxConfiguration')]",
          "customData": "[variables('cloudInitScript')]"
        },
        "storageProfile": {
          "imageReference": {
            "publisher": "canonical",
            "offer": "ubuntu-24_04-lts",
            "sku": "server",
            "version": "latest"
          },
          "osDisk": {
            "createOption": "FromImage",
            "managedDisk": { "storageAccountType": "Standard_LRS" },
            "diskSizeGB": 30
          }
        },
        "networkProfile": {
          "networkInterfaces": [
            {
              "id": "[resourceId('Microsoft.Network/networkInterfaces', variables('nicName'))]"
            }
          ]
        }
      }
    }
  ],
  "outputs": {
    "vmPublicIp": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Network/publicIPAddresses', variables('pipName'))).ipAddress]"
    },
    "sshCommand": {
      "type": "string",
      "value": "[concat('ssh ', parameters('adminUsername'), '@', reference(resourceId('Microsoft.Network/publicIPAddresses', variables('pipName'))).ipAddress)]"
    },
    "deployLogCommand": {
      "type": "string",
      "value": "[concat('ssh ', parameters('adminUsername'), '@', reference(resourceId('Microsoft.Network/publicIPAddresses', variables('pipName'))).ipAddress, ' \"tail -f /var/log/agent-deploy.log\"')]"
    },
    "serviceStatusCommand": {
      "type": "string",
      "value": "[concat('ssh ', parameters('adminUsername'), '@', reference(resourceId('Microsoft.Network/publicIPAddresses', variables('pipName'))).ipAddress, ' \"sudo systemctl status azure-support-agent\"')]"
    }
  }
}
